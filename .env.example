# ============================================
# LedgerLLC — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env — only this example file is tracked.
#
# RULE: anything prefixed NEXT_PUBLIC_ is shipped to the browser. Secrets
# (service role, encryption key, API secrets) MUST NOT use that prefix.

# --- Supabase (public; protected by Row Level Security) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Server-only secrets ---
# Service role key bypasses RLS — server code only.
SUPABASE_SERVICE_ROLE_KEY=

# 32-byte hex key for AES-256-GCM encryption of bank details / Plaid tokens.
# Generate with: openssl rand -hex 32
# WARNING: losing this key makes existing encrypted data UNRECOVERABLE.
ENCRYPTION_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Integrations (optional until those features are wired) ---
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# ANTHROPIC_API_KEY=

# --- Supabase Edge Function secrets (set in the Supabase dashboard, not here) ---
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are auto-provided to functions.
# RESEND_API_KEY is required by the net30-reminder function.
